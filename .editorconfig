# ============================================================
# .editorconfig — Standar format kode untuk semua anggota tim
# Dibaca otomatis oleh VS Code, PHPStorm, Sublime, dll.
# ============================================================

root = true

# Semua file
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# PHP, HTML, CSS, JS — indentasi 4 spasi
[*.{php,html,css,js}]
indent_style = space
indent_size  = 4

# SQL — indentasi 2 spasi
[*.sql]
indent_style = space
indent_size  = 2

# Markdown — jangan trim trailing whitespace (spasi 2x = line break)
[*.md]
trim_trailing_whitespace = false
