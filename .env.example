# ============================================================
# .env.example — Template konfigurasi environment
# CARA PAKAI: Copy file ini, rename jadi .env, lalu isi nilainya.
# JANGAN isi nilai asli di file ini (file ini di-commit ke Git).
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost        # Host database (biasanya localhost)
DB_NAME=gymsystem        # Nama database yang sudah diimport dari db.sql
DB_USER=root             # Username database
DB_PASS=                 # Password database (isi sesuai setup Laragon/XAMPP-mu)

# ── Environment ──────────────────────────────────────────────
# Gunakan 'development' saat coding lokal (error PHP tampil).
# Gunakan 'production' saat sudah di-deploy ke server (error disembunyikan).
APP_ENV=development